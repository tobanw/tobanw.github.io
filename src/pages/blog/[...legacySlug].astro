---
import BitLayout from "@layouts/BitLayout.astro";
import { getVisibleBits, legacySlugFromPermalink } from "@lib/content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getVisibleBits();
  return entries.map((entry) => ({
    params: { legacySlug: legacySlugFromPermalink(entry.data.permalink) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BitLayout entry={entry}>
  <Content />
</BitLayout>
