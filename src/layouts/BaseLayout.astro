---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import KeyboardHelp from "@components/KeyboardHelp.astro";
import { SITE } from "@lib/site";
import "@styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  bodyClass?: string;
  feedAlternates?: Array<{
    href: string;
    title: string;
    type?: string;
  }>;
}

const {
  title = SITE.title,
  description = SITE.description,
  canonical,
  bodyClass,
  feedAlternates = []
} = Astro.props;

const pageTitle = title === SITE.title ? SITE.title : `${title} / ${SITE.title}`;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, SITE.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (() => {
        let stored = null;
        try {
          stored = localStorage.getItem("theme");
        } catch {
          stored = null;
        }
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = stored || (systemDark ? "dark" : "light");
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title={`${SITE.name} Atom`} href="/atom.xml" />
    {
      feedAlternates.map((feed) => (
        <link
          rel="alternate"
          type={feed.type ?? "application/rss+xml"}
          title={feed.title}
          href={feed.href}
        />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="page-shell">
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>
    <KeyboardHelp />
    <script is:inline src="/scripts/theme.js?v=2" defer></script>
    <script is:inline src="/scripts/keyboard.js?v=2" defer></script>
  </body>
</html>
